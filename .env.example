# ================================
# APP CORE
# ================================
NEXT_PUBLIC_APP_NAME=JembeeKart
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development

# ================================
# THEME SYSTEM (GLASS MORPHISM)
# ================================
NEXT_PUBLIC_THEME_DEFAULT=glass
NEXT_PUBLIC_THEME_MODE=light
NEXT_PUBLIC_ENABLE_THEME_ADMIN=true
NEXT_PUBLIC_ENABLE_THEME_REALTIME=true

# UI TOKENS (glass UI design)
NEXT_PUBLIC_GLASS_BLUR=
NEXT_PUBLIC_GLASS_OPACITY=
NEXT_PUBLIC_GLASS_BORDER=
NEXT_PUBLIC_PRIMARY_COLOR=
NEXT_PUBLIC_SECONDARY_COLOR=

# ================================
# FIREBASE
# ================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ================================
# PAYMENT (CASHFREE)
# ================================
NEXT_PUBLIC_CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# ================================
# WHATSAPP API
# ================================
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# ================================
# SMS / EMAIL
# ================================
SMS_API_KEY=
EMAIL_API_KEY=

# ================================
# ANALYTICS
# ================================
NEXT_PUBLIC_GA_ID=

# ================================
# SECURITY
# ================================
JWT_SECRET=
ENCRYPTION_KEY=

# ================================
# QIKINK POD
# ================================
QIKINK_API_KEY=
QIKINK_API_SECRET=
QIKINK_BASE_URL=https://api.qikink.com

# ================================
# REALTIME / SOCKET
# ================================
NEXT_PUBLIC_SOCKET_URL=

# ================================
# FEATURE FLAGS
# ================================
NEXT_PUBLIC_ENABLE_REVIEWS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_VOICE_SEARCH=true
NEXT_PUBLIC_ENABLE_AFFILIATE=true
NEXT_PUBLIC_ENABLE_EXPERIMENTS=true