{
  "securitySystemEnabled": true,

  "adminControlledSecuritySystem": true,

  "securityStyle": "advanced_ai_security_system",

  "enableFirebaseAuthentication": true,

  "enableEmailPasswordLogin": true,

  "enablePhoneOTPLogin": true,

  "enableGoogleLogin": true,

  "enableTwoFactorAuthentication": true,

  "enableBiometricAuthentication": true,

  "enableRoleBasedAccessControl": true,

  "enableAdminAccessProtection": true,

  "enableSellerVerification": true,

  "enableFraudDetection": true,

  "enableRealtimeSecurityMonitoring": true,

  "enableLoginAttemptProtection": true,

  "enableDeviceTracking": true,

  "enableIPTracking": true,

  "enableSessionManagement": true,

  "enableAutomaticLogout": true,

  "enableAIThreatDetection": true,

  "enableSecurityAlerts": true,

  "enableRealtimeBackup": true,

  "enableEncryptedStorage": true,

  "enableSecureAPIRequests": true,

  "enableSecurePayments": true,

  "enableSecureFileUploads": true,

  "enableAdminAuditLogs": true,

  "enableUserActivityLogs": true,

  "enablePermissionManager": true,

  "securityRoles": [
    {
      "roleId": "super_admin",

      "roleName": "Super Admin",

      "permissions": [
        "full_access"
      ]
    },

    {
      "roleId": "admin",

      "roleName": "Admin",

      "permissions": [
        "dashboard_access",
        "theme_management",
        "layout_management",
        "seller_management",
        "user_management"
      ]
    },

    {
      "roleId": "seller",

      "roleName": "Seller",

      "permissions": [
        "store_management",
        "product_management",
        "order_management"
      ]
    },

    {
      "roleId": "affiliate",

      "roleName": "Affiliate",

      "permissions": [
        "affiliate_dashboard",
        "affiliate_links",
        "commission_tracking"
      ]
    },

    {
      "roleId": "reseller",

      "roleName": "Reseller",

      "permissions": [
        "reseller_dashboard",
        "product_sharing",
        "profit_tracking"
      ]
    },

    {
      "roleId": "user",

      "roleName": "User",

      "permissions": [
        "shopping",
        "orders",
        "wallet_access"
      ]
    }
  ],

  "desktopLayoutStyle": "advanced_security_dashboard",

  "mobileLayoutStyle": "stacked_mobile_security_dashboard"
}
