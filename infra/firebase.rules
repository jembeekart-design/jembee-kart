rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 🔹 Helper
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth.token.role == "admin";
    }

    // 📦 PRODUCT IMAGES
    match /images/products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 👤 USER AVATAR
    match /images/users/{userId}/{file} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }

    // 🎨 BANNERS (Admin only)
    match /images/banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ⚠️ TEMP UPLOADS
    match /temp/uploads/{userId}/{file} {
      allow read, write: if request.auth.uid == userId;
    }

    // ⚡ PROCESSED IMAGES (read only)
    match /processed/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}