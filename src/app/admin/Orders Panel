"use client";

import { useOrders } from "@/hooks/useOrders";

export default function OrdersAdmin() {
  const { orders } = useOrders();

  return (
    <div>
      <h1>Orders</h1>

      {orders.map((o: any) => (
        <div key={o.id}>
          {o.id} - {o.status}
        </div>
      ))}
    </div>
  );
}