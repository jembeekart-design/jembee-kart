{
  "glowroadIntegrationEnabled": true,

  "adminControlledGlowroadIntegration": true,

  "platformName": "GlowRoad",

  "platformType": "reseller_marketplace",

  "integrationMode": "catalog_sync_based",

  "apiConfiguration": {
    "apiKey": "",

    "apiSecret": "",

    "partnerId": "",

    "webhookSecret": ""
  },

  "catalogSettings": {
    "enableCatalogImport": true,

    "enableRealtimeCatalogSync": true,

    "enableAutomaticCategoryMapping": true,

    "enableSupplierProductSync": true
  },

  "resellerSettings": {
    "enableResellerProgram": true,

    "enableProfitMarginControl": true,

    "enableCustomSellingPrice": true,

    "enableOneClickReselling": true,

    "enableWhatsappSharing": true
  },

  "orderManagementSettings": {
