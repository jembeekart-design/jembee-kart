    "defaultCommissionPercentage": 20,

    "enableLevelBasedCommission": true,

    "enableReferralCommission": true
  },

  "analyticsSettings": {
    "enableSalesAnalytics": true,

    "enableTopResellerTracking": true,

    "enableProductPerformanceAnalytics": true,

    "enableRealtimeReports": true
  },

  "supportedFeatures": [
    "catalog_reselling",
    "whatsapp_selling",
    "supplier_products",
    "commission_earning",
    "reseller_dashboard",
    "mobile_reselling"
